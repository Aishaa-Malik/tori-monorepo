{
  "name": "toriate-monorepo",
  "private": true,
  "packageManager": "pnpm@9.12.3",
  "workspaces": [
    "apps/*",
    "apps/doubtfearcopy/frontend",
    "apps/doubtfearcopy/backend",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",

    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.8.7",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=20"
  },
  "resolutions": {
    "eslint-plugin-react": "^7.32.2",
    "eslint": "8.57.0"
  }
}